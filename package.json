{
  "name": "codebaxing",
  "version": "1.0.5",
  "description": "MCP server for semantic code search. Index your codebase and search using natural language.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codebaxing": "dist/cli/installer.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp/server.js",
    "dev": "tsx src/mcp/server.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-search",
    "semantic-search",
    "codebase-indexing",
    "tree-sitter",
    "embeddings",
    "vector-search",
    "claude",
    "ai"
  ],
  "author": "Street Devs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duysolo/codebaxing.git"
  },
  "homepage": "https://github.com/duysolo/codebaxing#readme",
  "bugs": {
    "url": "https://github.com/duysolo/codebaxing/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chromadb": "^1.9.2",
    "tree-sitter": "^0.22.4",
    "tree-sitter-bash": "^0.23.3",
    "tree-sitter-c": "^0.23.4",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-css": "^0.23.0",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-haskell": "^0.23.1",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-lua": "^2.1.3",
    "tree-sitter-make": "^1.1.1",
    "tree-sitter-ocaml": "^0.24.2",
    "tree-sitter-perl": "^1.0.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-toml": "^0.5.1",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-vue": "^0.2.1",
    "tree-sitter-yaml": "^0.5.0",
    "tree-sitter-zig": "^0.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "overrides": {
    "tree-sitter": "^0.22.4"
  }
}
